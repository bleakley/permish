#!/usr/bin/env python3
"""
permish: Run a command under OS-enforced sandbox with declared permissions.

The intent: an AI agent declares what permissions a command needs.
If the agent is wrong (the command tries to do more than declared), the OS
denies the syscall and the command exits non-zero. You don't have to read
or audit what the command actually does — the kernel does it for you.

Usage:
    permish [FLAGS] -- COMMAND [ARGS...]

Permission flags (compose freely; default is workspace-only reads, no writes, no network):
    --read-any    Allow reading the whole filesystem (outside the workspace).
    --write       Write to workspace + a fresh per-invocation $TMPDIR. .git stays read-only.
    --write-git   Write to workspace including .git (implies --write).
    --write-any   Allow writing anywhere on the filesystem (implies --read-any).
    --net         Allow network access.
    --full        No restrictions. Escape hatch — equivalent to running unwrapped.

Examples:
    # Read-only, restricted to the workspace (default)
    permish -- grep -r TODO .

    # Need to read outside the workspace (e.g. another repo, ~/.ssh/config)
    permish --read-any -- git log --stat

    # Write workspace but not .git, no network
    permish --write -- python process.py < input.csv

    # Need to write outside the workspace (e.g. pip install --user, npm -g)
    permish --write-any --net -- pip install --user requests

    # Full access for a package install
    permish --write-git --net -- npm install

Backend:
    Linux  → bubblewrap (bwrap) + network namespace
    macOS  → sandbox-exec with Seatbelt policy
    Windows → not supported (use WSL2 with bubblewrap)

Author: built for VS Code / generic AI agent workflows.
License: MIT — do whatever you want.
"""

import argparse
import os
import platform
import shutil
import signal
import subprocess
import tempfile
import sys
from pathlib import Path
from typing import List


# System paths bound read-only in default (workspace-only-reads) Linux mode.
# Enough to let binaries find their interpreter, shared libs, and basic config,
# but excludes /home, /root, /mnt, /media, /run/user (ssh-agent / dbus sockets),
# /var, etc.
_LINUX_SYSTEM_BIND_PATHS = [
    "/usr", "/bin", "/sbin", "/lib", "/lib64", "/lib32",
    "/etc",
]


# -----------------------------------------------------------------------------
# Linux backend: bubblewrap
# -----------------------------------------------------------------------------

def build_bwrap_command(
    read_any: bool, writes: bool, write_git: bool, write_any: bool, network: bool,
    workspace: Path, command: List[str],
    read_extra: List[str], write_extra: List[str],
) -> List[str]:
    args = [
        "bwrap",
        "--die-with-parent",
        "--new-session",
        "--unshare-pid",
        "--unshare-ipc",
        "--unshare-uts",
        "--unshare-cgroup-try",
        "--hostname", "sandbox",
        "--proc", "/proc",
        "--dev", "/dev",
        "--tmpfs", "/tmp",
    ]

    if not network:
        args += ["--unshare-net"]

    if write_any:
        # Writes everywhere implies reads everywhere on bwrap (you can't write
        # to a path that isn't mounted into the sandbox).
        args += ["--bind", "/", "/"]
    elif read_any:
        args += ["--ro-bind", "/", "/"]
    else:
        # Bind only system paths + workspace, not the full filesystem.
        # The user's home dir, other users' homes, and most of /var are absent.
        for p in _LINUX_SYSTEM_BIND_PATHS:
            if Path(p).exists():
                args += ["--ro-bind-try", p, p]

    ws = str(workspace)
    if writes or write_any:
        # Redundant when write_any (root already writable), but harmless and
        # ensures the .git carve-out below still applies.
        args += ["--bind", ws, ws]
        if not write_git:
            git_dir = workspace / ".git"
            if git_dir.exists():
                args += ["--ro-bind", str(git_dir), str(git_dir)]
    else:
        args += ["--ro-bind", ws, ws]

    for p in read_extra:
        args += ["--ro-bind-try", p, p]
    for p in write_extra:
        args += ["--bind-try", p, p]

    args += ["--chdir", str(workspace)]
    args += ["--"] + command
    return args


# -----------------------------------------------------------------------------
# macOS backend: sandbox-exec + Seatbelt
# -----------------------------------------------------------------------------

# Paths whose contents are *blocked* in default macOS mode (workspace-only reads).
# A pure deny-default policy breaks dyld / framework loading on modern macOS,
# so we instead allow file-read* broadly and then carve out the sensitive bits:
# every user's home dir, mounted volumes, and the root user's data.
_MACOS_BLOCKED_READ_PATHS = [
    "/Users",           # every user's home dir, including the current user
    "/Volumes",         # mounted external drives, network mounts, DMGs
    "/private/var/root",
]


def build_sandbox_exec_command(
    read_any: bool, writes: bool, write_git: bool, write_any: bool, network: bool,
    workspace: Path, tmp_dir: str, command: List[str],
    read_extra: List[str], write_extra: List[str],
) -> List[str]:
    parts = [
        "(version 1)",
        "(deny default)",
        "(allow process-fork)",
        "(allow process-exec)",
        "(allow signal (target self))",
        "(allow sysctl-read)",
        "(allow mach-lookup)",
        "(allow ipc-posix-shm)",
        "(allow iokit-open)",
        "(allow file-read-metadata)",
        # /dev/null is opened O_RDWR by many programs (git, shells, etc.).
        # Writing to it is always a no-op, so allow it in every mode.
        '(allow file-write* (literal "/dev/null"))',
    ]

    if read_any or write_any:
        parts.append("(allow file-read*)")
    else:
        # Allow reads broadly so dyld / frameworks / libs load, then deny the
        # sensitive trees (all user homes, mounted volumes, root's data) and
        # punch the workspace + a small tool-config allowlist back through.
        parts.append("(allow file-read*)")
        for p in _MACOS_BLOCKED_READ_PATHS:
            parts.append(f'(deny file-read* (subpath "{p}") (with no-log))')
        parts.append(f'(allow file-read* (subpath "{workspace}"))')
        parts.append(f'(allow file-read* (subpath "{tmp_dir}"))')
        home = str(Path.home())
        parts.append(f'(allow file-read* (literal "{home}/.gitconfig"))')
        parts.append(f'(allow file-read* (subpath "{home}/.config"))')

    if write_any:
        parts.append('(allow file-write*)')
        if not write_git:
            parts.append(f'(deny file-write* (subpath "{workspace}/.git"))')
    elif writes:
        parts.append(f'(allow file-write* (subpath "{workspace}"))')
        # Per-invocation TMPDIR (created by main, exposed to the child as
        # $TMPDIR). Replaces the previous blanket writes to /tmp, /private/tmp,
        # and /var/folders which exposed the user's whole caches dir.
        parts.append(f'(allow file-write* (subpath "{tmp_dir}"))')
        if not write_git:
            parts.append(f'(deny file-write* (subpath "{workspace}/.git"))')

    for p in read_extra:
        parts.append(f'(allow file-read* (subpath "{Path(p).resolve()}"))')
    for p in write_extra:
        parts.append(f'(allow file-write* (subpath "{Path(p).resolve()}"))')

    if network:
        parts.append("(allow network*)")
    else:
        # Localhost only. We use per-operation filters because `(local ip ...)`
        # against `network-outbound` matches the *source* address (typically
        # 0.0.0.0 on an unbound socket), which silently allows ALL outbound
        # traffic. For outbound we have to filter on `remote` instead.
        parts.append('(allow network-bind (local ip "localhost:*"))')
        parts.append('(allow network-inbound (local ip "localhost:*"))')
        parts.append('(allow network-outbound (remote ip "localhost:*"))')

    profile = "\n".join(parts)
    return ["sandbox-exec", "-p", profile] + command


# -----------------------------------------------------------------------------
# Driver
# -----------------------------------------------------------------------------

def detect_backend():
    system = platform.system()
    if system == "Linux":
        if not shutil.which("bwrap"):
            sys.stderr.write(
                "permish: bubblewrap (bwrap) not installed.\n"
                "  Debian/Ubuntu : sudo apt install bubblewrap\n"
                "  Fedora        : sudo dnf install bubblewrap\n"
                "  Arch          : sudo pacman -S bubblewrap\n"
            )
            sys.exit(127)
        return "bwrap"
    if system == "Darwin":
        if not shutil.which("sandbox-exec"):
            sys.stderr.write(
                "permish: sandbox-exec not found (should be on every macOS).\n"
            )
            sys.exit(127)
        return "sandbox-exec"
    sys.stderr.write(
        f"permish: unsupported OS: {system}.\n"
        "  On Windows, run permish inside WSL2 with bubblewrap installed.\n"
    )
    sys.exit(127)


def banner(
    read_any: bool, writes: bool, write_git: bool, write_any: bool, network: bool,
    full: bool, command: List[str],
):
    if full:
        label, icon = "full", "⚠️"
    else:
        parts = ["read-any" if (read_any or write_any) else "read"]
        if write_any:
            parts.append("write-any")
        elif write_git:
            parts.append("write+git")
        elif writes:
            parts.append("write")
        if network:
            parts.append("net")
        label = "+".join(parts)
        icon = "🌐" if network else "⚠️" if write_any else "🔧" if write_git else "✏️" if writes else "👁"
    sys.stderr.write(f"[permish] {icon} {label}  {' '.join(command)}\n")
    sys.stderr.flush()


def main():
    parser = argparse.ArgumentParser(
        prog="permish",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--read-any", action="store_true",
        help="Allow reading the whole filesystem. Default restricts reads to the workspace.",
    )
    parser.add_argument(
        "--write", action="store_true", dest="write",
        help="Allow writing to workspace + a fresh per-invocation $TMPDIR. .git stays read-only.",
    )
    parser.add_argument(
        "--write-git", action="store_true", dest="write_git",
        help="Allow writing to workspace including .git (implies --write).",
    )
    parser.add_argument(
        "--write-any", action="store_true", dest="write_any",
        help="Allow writing anywhere on the filesystem (implies --read-any).",
    )
    parser.add_argument(
        "--net", action="store_true",
        help="Allow network access.",
    )
    parser.add_argument(
        "--full", action="store_true",
        help="No restrictions. Escape hatch.",
    )
    parser.add_argument(
        "--workspace", default=os.getcwd(),
        help="Workspace root (default: cwd).",
    )
    parser.add_argument(
        "--read-path", dest="read_extra", action="append", default=[],
        metavar="PATH",
        help="Extra read-only path. Repeatable.",
    )
    parser.add_argument(
        "--write-path", dest="write_extra", action="append", default=[],
        metavar="PATH",
        help="Extra writable path. Repeatable.",
    )
    parser.add_argument(
        "--quiet", action="store_true",
        help="Suppress the [permish] banner on stderr.",
    )
    parser.add_argument(
        "--explain", action="store_true",
        help="Print the sandbox command that would run, then exit 0.",
    )
    parser.add_argument(
        "command", nargs=argparse.REMAINDER,
        help="Command to run (precede with -- to be safe).",
    )

    args = parser.parse_args()

    # Strip a leading "--" if argparse left it in (it does, with REMAINDER).
    command = list(args.command)
    if command and command[0] == "--":
        command = command[1:]
    if not command:
        parser.error("no command supplied — put the command after `--`")

    read_any   = args.read_any or args.write_any
    write_git  = args.write_git
    write_any  = args.write_any
    writes     = args.write or write_git or write_any
    network    = args.net
    full       = args.full

    workspace = Path(args.workspace).resolve()
    if not workspace.exists():
        sys.stderr.write(f"permish: workspace {workspace} does not exist\n")
        sys.exit(2)

    if not args.quiet:
        banner(read_any, writes, write_git, write_any, network, full, command)

    if full:
        if args.explain:
            sys.stderr.write(f"[permish] would exec:\n  {' '.join(command)}\n")
            return 0
        try:
            os.execvp(command[0], command)
        except FileNotFoundError as e:
            sys.stderr.write(f"permish: {e}\n")
            sys.exit(127)
        return

    backend = detect_backend()

    if backend == "bwrap":
        wrapped = build_bwrap_command(
            read_any, writes, write_git, write_any, network,
            workspace, command, args.read_extra, args.write_extra,
        )
        if args.explain:
            sys.stderr.write("[permish] would exec:\n  " + " ".join(wrapped) + "\n")
            return 0
        # bwrap's --tmpfs /tmp already gives us a fresh, isolated temp area,
        # so execvp is fine here.
        try:
            os.execvp(wrapped[0], wrapped)
        except FileNotFoundError as e:
            sys.stderr.write(f"permish: {e}\n")
            sys.exit(127)
        return

    # macOS: sandbox-exec has no tmpfs equivalent. Create a fresh per-invocation
    # temp dir, point $TMPDIR at it for the child, and rm -rf it on exit. This
    # replaces the previous blanket writes to /tmp, /private/tmp, and /var/folders
    # (which exposed the user's whole caches tree under /var/folders/.../C/).
    with tempfile.TemporaryDirectory(prefix="permish-") as tmp_dir:
        tmp_dir = str(Path(tmp_dir).resolve())
        wrapped = build_sandbox_exec_command(
            read_any, writes, write_git, write_any, network,
            workspace, tmp_dir, command, args.read_extra, args.write_extra,
        )
        if args.explain:
            sys.stderr.write("[permish] would exec:\n  " + " ".join(wrapped) + "\n")
            return 0
        env = dict(os.environ, TMPDIR=tmp_dir + "/")
        sys.exit(_run_and_forward(wrapped, env))


def _run_and_forward(cmd: List[str], env: dict) -> int:
    """Run cmd with signal forwarding; return shell-style exit code."""
    try:
        proc = subprocess.Popen(cmd, env=env)
    except FileNotFoundError as e:
        sys.stderr.write(f"permish: {e}\n")
        return 127

    def _forward(signum, _frame):
        try:
            proc.send_signal(signum)
        except ProcessLookupError:
            pass

    for sig in (signal.SIGINT, signal.SIGTERM, signal.SIGHUP, signal.SIGQUIT):
        try:
            signal.signal(sig, _forward)
        except (ValueError, OSError):
            pass

    rc = proc.wait()
    # Mirror shell convention: signal N -> exit 128+N.
    return rc if rc >= 0 else 128 + (-rc)


if __name__ == "__main__":
    main()
